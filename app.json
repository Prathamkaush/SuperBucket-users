{
  "expo": {
    "name": "Superbuket",
    "slug": "superbuket-user",
    "version": "1.0.7",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/images/app-icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.superbuket.user",
      "buildNumber": "8",
      "icon": "./assets/images/app-icon.png"
    },
    "android": {
      "package": "com.superbuket.user",
      "versionCode": 8,
      "icon": "./assets/images/app-icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "usesCleartextTraffic": true
    },
    "web": {},
    "extra": {
      "eas": {
        "projectId": "7b804857-569c-4bf5-aace-f4c77fa50f84"
      }
    },
    "owner": "hiteshkaushik33",
    "plugins": [
      "@react-native-google-signin/google-signin",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow SuperBucket to use your location to auto-detect your delivery address."
        }
      ]
    ]
  }
}
